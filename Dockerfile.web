FROM node:20-alpine

WORKDIR /app

# Install root workspace deps used by the web workspace.
COPY package.json package-lock.json ./
COPY web/package.json ./web/package.json
RUN npm ci

# Copy app source.
COPY web ./web

EXPOSE 3000

CMD ["npm", "--workspace=web", "run", "dev", "--", "--hostname", "0.0.0.0", "--port", "3000"]
