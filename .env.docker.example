# ─────────────────────────────────────────────────────────────────────────────
# ClipFarm — Docker environment template
# Copy to .env.docker and fill in real values before running docker compose.
#
#   cp .env.docker.example .env.docker
#   docker compose --env-file .env.docker up --build
# ─────────────────────────────────────────────────────────────────────────────

# ── Local Postgres (used by the db container) ─────────────────────────────────
POSTGRES_DB=clipfarm
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ── Database ──────────────────────────────────────────────────────────────────
# Option A (default): point at your Supabase pooler
DATABASE_URL=postgresql+asyncpg://<user>:<password>@<host>:5432/postgres
# Option B: use the local Postgres container
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/clipfarm

# ── Auth ──────────────────────────────────────────────────────────────────────
# Any long random string — used to sign JWTs
JWT_SECRET=change-me-use-a-long-random-string

# ── Supabase ──────────────────────────────────────────────────────────────────
# Found in: Supabase dashboard → Project Settings → API
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>        # keep this secret — server only
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-public-key>     # safe to expose in the browser

# ── Cloudflare R2 (video + clip storage) ─────────────────────────────────────
# Found in: Cloudflare dashboard → R2 → Manage API Tokens
R2_ACCOUNT_ID=<cloudflare-account-id>
R2_ACCESS_KEY_ID=<r2-access-key-id>
R2_SECRET_ACCESS_KEY=<r2-secret-access-key>
R2_PUBLIC_URL=https://<your-bucket>.r2.dev          # public URL for serving clips

# ── Roboflow (ball detection model) ──────────────────────────────────────────
# Found in: Roboflow dashboard → Settings → API Keys
ROBOFLOW_API_KEY=<roboflow-api-key>

# ── Modal (optional — GPU inference) ─────────────────────────────────────────
# Leave blank to skip Modal and run inference locally (slow on CPU)
# Found in: modal.com → Settings → API Tokens
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=
